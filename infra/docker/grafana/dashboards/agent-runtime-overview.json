{
  "id": null,
  "title": "Forex Platform - Agent Runtime Overview",
  "tags": ["forex", "agentic_v2", "runtime", "agents"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Agentic Runs / min",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(agentic_runtime_runs_total[5m])) * 60",
          "legendFormat": "runs/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Agentic Failure Rate (%)",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {
          "expr": "100 * sum(rate(agentic_runtime_runs_total{status=\"failed\"}[5m])) / clamp_min(sum(rate(agentic_runtime_runs_total[5m])), 0.0001)",
          "legendFormat": "failed %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Planner Degraded / min",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(agentic_runtime_tool_selections_total{degraded=\"true\"}[5m])) * 60",
          "legendFormat": "degraded/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Memory Refresh / min",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(agentic_runtime_memory_refresh_total[5m])) * 60",
          "legendFormat": "refresh/min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Runs / min by Status",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {
          "expr": "sum(rate(agentic_runtime_runs_total[5m])) by (status, mode) * 60",
          "legendFormat": "{{status}} / {{mode}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Final Decisions / min",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {
          "expr": "sum(rate(agentic_runtime_final_decisions_total[5m])) by (decision, mode) * 60",
          "legendFormat": "{{decision}} / {{mode}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Planner Tool Selections / min",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "expr": "sum(rate(agentic_runtime_tool_selections_total[5m])) by (tool, source) * 60",
          "legendFormat": "{{tool}} / {{source}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "decimals": 2
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Runtime Tool Latency p95 (s)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(agentic_runtime_tool_duration_seconds_bucket[5m])) by (le, tool))",
          "legendFormat": "{{tool}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      }
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Specialist Step Latency p95 (s)",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(orchestrator_step_duration_seconds_bucket[5m])) by (le, agent))",
          "legendFormat": "{{agent}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 3
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Execution Outcomes / min",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {
          "expr": "sum(rate(agentic_runtime_execution_outcomes_total[5m])) by (status, mode) * 60",
          "legendFormat": "{{status}} / {{mode}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "cpm",
          "decimals": 2
        },
        "overrides": []
      }
    }
  ]
}
