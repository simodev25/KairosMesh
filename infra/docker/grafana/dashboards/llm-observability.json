{
  "id": null,
  "title": "Forex Platform - LLM & Orchestrator",
  "tags": ["forex", "llm", "orchestrator"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "panels": [
    {
      "type": "timeseries",
      "title": "LLM Calls / min",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum(rate(llm_calls_total[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM Latency p95 (s)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(llm_latency_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "LLM Estimated Cost USD / min",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "sum(rate(llm_cost_usd_total[1m])) by (model)",
          "legendFormat": "{{model}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Orchestrator Step Latency p95 (s)",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(orchestrator_step_duration_seconds_bucket[5m])) by (le, agent))",
          "legendFormat": "{{agent}}"
        }
      ]
    }
  ]
}
